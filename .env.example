# Тот же Postgres, что у cetatenie-mvp (таблицы stadiu_*), или отдельная БД.
# DATABASE_URL=

# Локально без Postgres:
# SQLITE_PATH=./data/stadiu.db

PG_CONNECT_TIMEOUT=120

# Список stadiu-dosar (Selenium)
# STADIU_PAGE_URL=https://cetatenie.just.ro/stadiu-dosar/
# MAX_NEW_STADIU_DOWNLOADS=1
# COLD_START_MAX_STADIU_PDFS=3
# Повторы HTTP / пауза между PDF (Connection refused, rate limit)
# STADIU_HTTP_DOWNLOAD_ATTEMPTS=5
# STADIU_LIST_HTTP_ATTEMPTS=4
# STADIU_HTTP_RETRY_BASE_SEC=3
# STADIU_SELENIUM_DOWNLOAD_ATTEMPTS=3
# STADIU_BETWEEN_PDF_SEC=8
# Тот же URL, но PDF на сервере мог обновиться: перекачка раз в N дней (0 = только новые URL).
# STADIU_REFRESH_AFTER_DAYS=7
# MAX_STADIU_REFRESH_PER_RUN=2
# PAGE_LOAD_TIMEOUT=120
# LIST_PAGE_WAIT_TIMEOUT=90
# Пауза после появления контента stadiu-dosar (лоадер / вкладки), сек
# STADIU_LIST_SETTLE_SEC=12
# HEADLESS=1

# Планировщик (минуты между прогонами; каждый прогон = снова HTML и разбор ссылок Art.11)
# POLL_INTERVAL_MIN_MINUTES=30
# POLL_INTERVAL_MAX_MINUTES=45
# Фиксированный интервал вместо случайного (0 = выключено). Пример 240 ≈ 6 раз/сутки.
# STADIU_LIST_POLL_MINUTES=0

# По умолчанию в коде: только Selenium+UA. Включить «голый» HTTP (меньше RAM, риск 503/бана):
# STADIU_PREFER_HTTP_PDF=1
# STADIU_PREFER_HTTP_LIST=1
# Парсинг PDF в отдельном процессе (pdfplumber); 0 = в том же процессе.
# STADIU_PARSE_PDF_SUBPROCESS=1
# Доп. флаги Chromium в контейнере; 0 если браузер падает при старте.
# STADIU_CHROME_LOW_MEMORY=1
# В Docker: MALLOC_ARENA_MAX=2 снижает фрагментацию кучи glibc.

# Docker / Railway: см. Dockerfile (CHROME_BIN, CHROMEDRIVER_PATH)
